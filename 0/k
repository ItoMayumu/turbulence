FoamFile
{
    version    2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions [0 2 -2 0 0 0 0];

internalField uniform 5.69e-05;

boundaryField
{
    INLET
    {
        type      fixedValue;
        value     $internalField;
    }
    OUTLET
    {
        type      zeroGradient;
    }
    WALL
    {
        type     kqRWallFunction;
        value    $internalField;
    }
}