FoamFile
{
    version    2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}

dimensions [0 2 -3 0 0 0 0];
internalField uniform 1.41e-06;

boundaryField
{
    INLET
    {
        type      fixedValue;
        value     $internalField;
    }
    OUTLET
    {
        type      zeroGradient;
    }
    WALL
    {
        type     epsilonWallFunction;
        value    $internalField;
    }
}