FoamFile
{
    version    2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}

dimensions [0 2 -1 0 0 0 0];
internalField uniform 0;

boundaryField
{
    INLET
    {
        type      calculated;
        value     uniform 0;
    }
    OUTLET
    {
        type      calculated;
        value     uniform 0;
    }
    WALL
    {
        type     nutkRoughWallFunction;
        value    uniform 0;
        Ks              uniform 0;      
        Cs              uniform 0.5;
    }
}